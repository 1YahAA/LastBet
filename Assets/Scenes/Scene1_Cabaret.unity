  characters:
  - characterId: Victor
    displayName: "\u0412\u0438\u043A\u0442\u043E\u0440"
    characterSprite: {fileID: 18415609879096955, guid: d1801267c2eddd5499fbe24f71ec6e57, type: 3}
    thoughts: "\u041E\u043D\u0430 \u043F\u043E\u0451\u0442 \u043B\u0443\u0447\u0448\u0435,
      \u043A\u043E\u0433\u0434\u0430 \u0431\u043E\u0438\u0442\u0441\u044F. \u0421\u0442\u0440\u0430\u0445
      \u0434\u0435\u043B\u0430\u0435\u0442 \u0433\u043E\u043B\u043E\u0441 \u0447\u0438\u0449\u0435."
  - characterId: Leo
    displayName: "\u041B\u0435\u043E"
    characterSprite: {fileID: 6535060745936091336, guid: 46ba483c864fff147980af30704e9740, type: 3}
    thoughts: "\u041A\u0440\u0430\u0441\u0438\u0432\u0430\u044F \u043F\u0442\u0438\u0446\u0430.
      \u0416\u0430\u043B\u044C, \u0447\u0442\u043E \u043A\u043B\u0435\u0442\u043A\u0430
      \u0442\u0430\u043A\u0430\u044F \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0430\u044F."
  - characterId: Mari
    displayName: "\u041C\u0430\u0440\u0438"
    characterSprite: {fileID: -3613270933863246583, guid: fe7713e82ce7a314abe9b6987cc02a61, type: 3}
    thoughts: "\u0412\u0441\u0451 \u043F\u043E\u0434 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0435\u043C.
      \u041A\u0430\u043A \u0432\u0441\u0435\u0433\u0434\u0430. \u041A\u0430\u043A
      \u0434\u043E\u043B\u0436\u043D\u043E \u0431\u044B\u0442\u044C."
  - characterId: Helga
    displayName: "\u0425\u0435\u043B\u044C\u0433\u0430"
    characterSprite: {fileID: -4209873714772210266, guid: dfdec4f5f61131c4eb25240d96a2946c, type: 3}
    thoughts: "\u0414\u043E\u043B\u0433\u043E \u043B\u0438 \u043E\u043D\u0430 \u043F\u0440\u043E\u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F?
      \u0412\u0438\u043A\u0442\u043E\u0440 \u043D\u0435 \u043B\u044E\u0431\u0438\u0442,
      \u043A\u043E\u0433\u0434\u0430 \u0438\u0433\u0440\u0443\u0448\u043A\u0438 \u043B\u043E\u043C\u0430\u044E\u0442\u0441\u044F."
